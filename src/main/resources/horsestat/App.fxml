<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="background" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="horsestat.HorseStatController">
   <children>
      <Label layoutX="14.0" layoutY="8.0" prefHeight="32.0" prefWidth="390.0" text="Horse Statistics Manager">
         <font>
            <Font size="25.0" />
         </font>
      </Label>
      <TableView fx:id="tableView" layoutX="1.0" layoutY="50.0">
        <columns>
          <TableColumn fx:id="nameColumn" text="Name" />
          <TableColumn fx:id="speedColumn" text="Speed" />
            <TableColumn fx:id="jumpColumn" text="Jump" />
            <TableColumn fx:id="healthColumn" text="Health" />
            <TableColumn fx:id="averageColumn" text="Average" />
        </columns>
      </TableView>
      <TextField fx:id="name" layoutX="400.0" layoutY="60.0" prefHeight="26.0" prefWidth="70.0" promptText="Name" />
      <TextField fx:id="speed" layoutX="400.0" layoutY="95.0" prefHeight="26.0" prefWidth="70.0" promptText="Speed" />
      <TextField fx:id="jump" layoutX="400.0" layoutY="130.0" prefHeight="26.0" prefWidth="70.0" promptText="Jump" />
      <TextField fx:id="health" layoutX="400.0" layoutY="165.0" prefHeight="26.0" prefWidth="70.0" promptText="Health" />
      <Button fx:id="addButton" layoutX="400.0" layoutY="200.0" mnemonicParsing="false" onAction="#addClick" prefHeight="26.0" prefWidth="70.0" text="Add" />
      <Button fx:id="sortButton" layoutX="400.0" layoutY="235.0" mnemonicParsing="false" onAction="#sortClick" prefHeight="26.0" prefWidth="70.0" text="Sort" />
      <Button fx:id="deleteButton" layoutX="400.0" layoutY="270.0" mnemonicParsing="false" onAction="#deleteClick" prefHeight="26.0" prefWidth="70.0" text="Delete" />
      
   </children>
</AnchorPane>
